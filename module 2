<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flashcard - Language App</title>

<style>
  /* Base Layout */
  body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: #f2f2f2;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    margin: 0;
  }

  /* Container for the 3D perspective */
  .flashcard-container {
    perspective: 1000px;
  }

  /* The actual card */
  .flashcard {
    width: 300px;
    height: 200px;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }

  /* Flip action */
  .flashcard.flipped {
    transform: rotateY(180deg);
  }

  /* Common styling for both faces */
  .card-face {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden; /* Important: hides the back side of the face */
    border-radius: 15px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    font-weight: bold;
    box-shadow: 0 8px 15px rgba(0,0,0,0.1);
  }

  .label {
    font-size: 0.8rem;
    text-transform: uppercase;
    opacity: 0.8;
    margin-bottom: 10px;
  }

  .word {
    font-size: 2rem;
    margin: 0;
  }

  /* Front styling */
  .front {
    background: #007bff;
    color: white;
  }

  /* Back styling */
  .back {
    background: #28a745;
    color: white;
    transform: rotateY(180deg); /* Pre-flip the back face */
  }
</style>

</head>
<body>

<div class="flashcard-container">
  <div class="flashcard" onclick="this.classList.toggle('flipped')">
    
    <div class="card-face front">
      <span class="label">English</span>
      <h2 class="word">Ephemeral</h2>
    </div>
    
    <div class="card-face back">
      <span class="label">Spanish</span>
      <h2 class="word">Efímero</h2>
    </div>

  </div>
</div>

</body>
</html>